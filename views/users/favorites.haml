.header
  %h2=title(t("My_favorites", user: @user[:name]))

:javascript
  $(document).ready(function() {
    $(".editable-group-public").editable({
        type: 'select',
        source: [{value:0, text:"#{t("favorites.Private")}"},
                 {value:1, text:"#{t("favorites.Public")}"}],
        onblur:'submit',
        ajaxOptions: {
            type: 'put'
        }
    });

  });

%ul.breadcrumb
  %li
    %a{:href=>"/user/#{@user[:id]}"}=@user[:name]
  %li.active
    =t(:My_favorites)

%h3=t("favorites.My_Categories")

%form.form-inline{:action => "/favorite_groups/new", :method => "post"}
  .form-group
    %input.form-control{:name => "name", :placeholder => t("favorites.New_category_name"), :required => true}
  .checkbox
    %label
      %input{:type => "checkbox", :name => "is_public", :value => "true"}
      =t("favorites.Make_public")
  %button.btn.btn-default{:type => "submit"}
    %span.glyphicon.glyphicon-plus
    =t(:Add)
%p

- if @favorite_groups.empty?
  %p
    %em=t("favorites.No_categories_created")
- else
  %table.table-bordered.table-sm
    %thead
      %tr
        %th=t(:Name)
        %th=t(:Description)
        %th=t(:Visibility)
        %th=t(:Actions)
    %tbody
      - @favorite_groups.each do |group|
        %tr
          %td
            =a_editable(group.id, "favorite_group_name", "/favorite_groups/#{group.id}/edit_field/name", group.name, "")
          %td
            =a_editable(group.id, "favorite_group_description", "/favorite_groups/#{group.id}/edit_field/description", group.description, "")
          %td
            %a{:href => "#", :id=>"editable_favorite_public_#{group.id}",
            :class => "editable-group-public", "data-url"=>url("/favorite_groups/#{group.id}/edit_field/is_public"),
            "data-pk" => group.id, "data-value" => group.is_public ? "1" : "0"}
          %td
            %a.btn.btn-danger.btn-xs{:href => "/favorite_group/#{group.id}/delete", :onclick => "return confirm('#{t(:Are_you_sure)}?');"}
              %span.glyphicon.glyphicon-trash

%h3=t("favorites.My_Favorite_Documents")

- if @favorite_documents.empty?
  %p
    %em=t("favorites.No_favorites_yet")
- else
  %form{:id => "favorites_#{@user[:id]}", :action => "/favorites/user/#{@user[:id]}/update", :method => "post"}
    %table.table-bordered.table-sm
      %thead
        %tr
          %th=t(:Active)
          %th=t(:Document)
          %th=t(:Category)
          %th=t(:Commentary)
      %tbody
        - @favorite_documents.each do |fav|
          %tr
            %td
              %input{:type=>"checkbox", :name => "favorites[#{fav[:canonical_document_id]}][activo]", :checked => fav[:activo]}
            %td
              %strong=fav[:title]
              %p="#{fav[:author]} (#{fav[:year]})"
            %td
              %select.form-control.input-sm{:name => "favorites[#{fav[:canonical_document_id]}][group_id]"}
                %option{:value => ""}=t("favorites.No_category")
                - @favorite_groups.each do |group|
                  %option{:value => group.id, :selected => (group.id == fav[:group_id])}=group.name
            %td
              %textarea.form-control{:name => "favorites[#{fav[:canonical_document_id]}][commentary]", :rows=>2}=fav[:commentary]
    %button.btn.btn-sm.btn-success{:type => "submit"}
      %span.glyphicon.glyphicon-save
      =t(:Save)
