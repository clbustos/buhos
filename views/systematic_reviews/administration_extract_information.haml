.heading
  =t_systematic_review_title(@review[:name], "systematic_review_page.#{@stage}_administration")

=partial(:breadcrumb_review_admin,:locals=>{:name=>t(@name_stage)})

%p.info=t_desc_value(:Count_canonical_documents, @cds_id.length)
- stats=@extract_information_stats
- progress_filter=params['progress_status'].to_s
- progress_options={'all'=>'Todos', 'complete'=>'Completos', 'pending_information'=>'Pendientes de información', 'pending_quality'=>'Pendientes de calidad', 'incomplete'=>'Incompletos'}
- filtered_document_statuses=stats[:document_statuses]
- if progress_filter!='' && progress_filter!='all'
  - filtered_document_statuses=filtered_document_statuses.find_all {|document_status| document_status[:progress_status]==progress_filter}

.btn-group
  %a.btn.btn-sm.btn-default{:href=>"/review/#{@review[:id]}/administration/#{@stage}/cd_assignations"}
    %span.glyphicon.glyphicon-list
    =t(:Check_CD_assignations)
  - if !@cd_without_allocation.empty?
    %a.btn.btn-sm.btn-warning{:href=>"/review/#{@review[:id]}/administration/#{@stage}/cd_without_allocations"}
      %span.glyphicon.glyphicon-list
      =t(:Check_CD_without_assignations)
      %span.badge=@cd_without_allocation.count

%h3=t(:Stage_status)

- if stats[:stage_complete]
  %p.alert.alert-success=t(:extract_information_complete)
- else
  %p.alert.alert-warning=t(:extract_information_incomplete)

%h4 Estadística total
%table.reporte
  %thead
    %th Completos
    %th Total
  %tbody
    - stats[:total_stats].each do |total_stat|
      %tr
        %th="#{total_stat[:complete_label]}: #{total_stat[:complete_count]}"
        %td=total_stat[:total_count]

- if stats[:quality_active]
  %p.info="Control de calidad activo: #{stats[:quality_criteria_count]} criterios definidos."
- else
  %p.info Control de calidad no activo para esta revisión.

%h4 Usuarios
%table.reporte
  %thead
    %th=t(:User)
    %th Documentos completos
  %tbody
    - stats[:user_statuses].each do |user_status|
      - user=user_status[:user]
      %tr
        %th= user ? user.name : user_status[:user_id]
        %td="#{user_status[:complete_count]} / #{user_status[:assigned_count]}"

%h4 Documentos canónicos
%form.form-inline{:method=>:get, :action=>url("/review/#{@review[:id]}/administration/#{@stage}")}
  .form-group
    %label{:for=>'progress_status'} Estado de avance
    %select.form-control.input-sm{:name=>'progress_status', :id=>'progress_status'}
      - progress_options.each do |value,label|
        %option{:value=>value, :selected=>(progress_filter==value || (progress_filter=='' && value=='all'))}=label
  %button.btn.btn-default.btn-sm{:type=>:submit}
    %span.glyphicon.glyphicon-filter
    Filtrar

%table.reporte
  %thead
    %th=t(:Canonical_document)
    %th Asignaciones
    %th Formulario
    %th Archivos
    - if stats[:quality_active]
      %th Calidad
    %th Estado
  %tbody
    - filtered_document_statuses.each do |document_status|
      - cd=@cds_hash[document_status[:canonical_document_id]]
      %tr
        %td
          %a{:href=>url("/review/#{@review[:id]}/administration/#{@stage}/cd/#{document_status[:canonical_document_id]}")}= cd ? cd[:title] : document_status[:canonical_document_id]
        %td=document_status[:assigned_count]
        %td= document_status[:has_form_information] ? t(:Yes) : t(:No)
        %td= document_status[:has_file_information] ? t(:Yes) : t(:No)
        - if stats[:quality_active]
          %td= document_status[:has_quality] ? t(:Yes) : t(:No)
        %td= document_status[:complete] ? "Completo" : "Incompleto"

=partial(:sr_administration_actions, :locals=>{review:@review, stage:@stage})
